[html]
<div style="
position:fixed;
left:10px;
bottom:10px;
font-size:12px;
color:#fff;
text-shadow:1px 1px 2px #000;
z-index:9999;
pointer-events:none;
">
纪念《恶魔连结》（暂时） ｜ 与《恶魔连结》一样的TyranoScript引擎
</div>
[endhtml]
; 让整个画面都可以点击推进
[link target=*next]
[button graphic=""]  ; 透明按钮铺满全屏
[endlink]

; 或者用宏定义全局点击区域
[macro name=waittap]
    [wait tap=true canvas=true]
[endmacro]
